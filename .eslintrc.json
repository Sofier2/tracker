{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:jest/recommended"
  ],
  "plugins": ["jest"],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {},
  "overrides": [
    {
      "files": ["**/_tests/**/*.js", "**/*.test.js"],
      "env": {
        "jest": true
      }
    }
  ]
}